pragma circom 2.0.0;

template H(x) {
    signal output out[32];
    var lo[8] = [
        0xe667, 0xae85, 0xf372, 0xf53a, 0x527f, 0x688c, 0xd9ab, 0xcd19
    ];
    var hi[8] = [
        0x6a09, 0xbb67, 0x3c6e, 0xa54f, 0x510e, 0x9b05, 0x1f83, 0x5be0
    ];

    for (var i = 0; i < 16; i++) {
        out[i] <== (lo[x] >> i) & 1;
        out[i + 16] <== (hi[x] >> i) & 1;
    }
}

